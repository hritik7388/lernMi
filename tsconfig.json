{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

   "target": "ES2021",
    "module": "commonjs", 
    "esModuleInterop": true,
    "strict": true, "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "common/*"
      ],
      "@src/*": [
        "src/*"
      ]
    }
  },

  "include": [
    "src",
    "common"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}